{
  "name": "@stitchstudio/registry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "bun run typecheck && bun run lint && bun run test && bun run format:check && bun run registry:validate",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "registry:audit": "bun scripts/validate-registry.ts",
    "registry:build": "shadcn build ./registry.json -o ./public/r && oxfmt --write ./public/r",
    "registry:validate": "shadcn registry validate ./registry.json && bun run registry:audit",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@phosphor-icons/react": "^2.1.10",
    "@shadcn/react": "^0.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "react-day-picker": "^10.0.1",
    "react-hook-form": "^7.80.0",
    "react-resizable-panels": "^4.12.0",
    "recharts": "3.9.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.12.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "overrides": {
    "immer": "11.1.9"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
